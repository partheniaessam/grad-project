{
  "expo": {
    "name": "workout-ui-sandbox",
    "slug": "workout-ui-sandbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "workoutuisandbox",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.workoutuisandbox"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow workout-ui-sandbox to access your camera to track your movements."
        }
      ]
    ],
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    }
  }
}